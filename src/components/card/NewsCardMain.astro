---
import { Icon } from "astro-icon/components";
import { formatFrontmatterDate } from "../../utils/date";
import { Image } from "astro:assets";
import { BASE_URL } from "../../utils/base";

const { id, data } = Astro.props;

// Aseguramos que la miniatura, si es string, tenga la base
const thumbnailSrc =
    typeof data.thumbnail === "string"
        ? `${BASE_URL}${data.thumbnail.replace(/^\//, "")}`
        : data.thumbnail;
---

<article
    class="group h-full flex flex-col gap-3 border border-gray-200 overflow-hidden rounded-xl"
>
    {
        data.thumbnail && (
            <div class="grid">
                <a href={`${BASE_URL}blog/${id}`} class="[grid-area:1/1/2/2]">
                    <Image
                        src={thumbnailSrc}
                        alt={data.title}
                        width="500"
                        height="250"
                        format="webp"
                        quality={45}
                        class="aspect-2/1 w-full h-auto object-cover "
                    />
                </a>
                <a
                    href={`${BASE_URL}blog/${data.category.slug}`}
                    class="btn bg-main border-main shadow-none text-white px-3 py-1 h-auto text-xs rounded-md [grid-area:1/1/2/2] mb-auto mr-auto mt-2 ml-2"
                >
                    {data.category.title}
                </a>
            </div>
        )
    }

    <div
        class="text-center w-full flex-1 flex flex-col justify-between items-center p-4"
    >
        <p
            class="flex flex-wrap gap-2 gap-x-4 items-center uppercase justify-center text-sm mb-4"
        >
            <a
                href={`${BASE_URL}auhors/${data.author.id}`}
                class="hover:underline">{data.author.name}</a
            >
            <time datetime={data.pubDate.toISOString()}>
                {formatFrontmatterDate(data.pubDate)}
            </time>
        </p>
        <a
            href={`${BASE_URL}blog/${id}`}
            class="flex-1 flex flex-col justify-between w-full"
        >
            <h3 class="font-semibold text-xl sm:text-2xl group-hover:underline">
                {data.title}
            </h3>
            <p class="mb-6 text-sm sm:text-base">{data.description}</p>

            <button
                class="btn bg-main border-main text-white rounded-lg hover:bg-red-900 w-full mt-auto"
            >
                Read more
                <Icon name="lucide:arrow-up-right" size={16} />
            </button>
        </a>
    </div>
</article>
